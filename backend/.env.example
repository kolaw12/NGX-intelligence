# App
APP_ENV=development
LOG_LEVEL=INFO

# Broadstreet
BROADSTREET_BASE_URL=
BROADSTREET_USERNAME=
BROADSTREET_PASSWORD=
BROADSTREET_API_KEY=

# CBN (Central Bank of Nigeria)
CBN_BASE_URL=

# yfinance (no key required, kept for overrides)
YFINANCE_PROXY=

# Storage
DATA_OUTPUT_DIR=data/output
DATA_LOG_DIR=data/logs

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/ngx_ai
POSTGRES_PRICE_WINDOW_DAYS=

# Runtime
ENV=development
FRONTEND_URL=http://localhost:5173
# Optional comma-separated list for deployed frontend and preview URLs.
# Example: FRONTEND_URLS=https://your-frontend.vercel.app,https://your-custom-domain.com
FRONTEND_URLS=
NUPAT_DISABLE_FINBERT=0

# Model ensemble
XGB_ENSEMBLE_WEIGHT=0.60
LSTM_ENSEMBLE_WEIGHT=0.40
